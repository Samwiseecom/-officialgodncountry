<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Official God & Country - Clearance Sales UP TO 65% OFF</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Arial', sans-serif; background: #000; color: #fff; overflow-x: hidden; }
        .container { max-width: 1400px; margin: 0 auto; padding: 0 20px; }

        /* Navigation */
        .navbar { background: #111; padding: 15px 0; position: fixed; width: 100%; top: 0; z-index: 1000; box-shadow: 0 2px 10px rgba(255,255,255,0.1); }
        .nav-container { display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 28px; font-weight: bold; letter-spacing: 2px; }
        .nav-menu { display: flex; list-style: none; gap: 30px; }
        .nav-menu a { color: #fff; text-decoration: none; font-weight: 500; transition: color 0.3s; }
        .nav-menu a:hover { color: #ccc; }
        .cart-btn { background: #fff; color: #000; padding: 12px 25px; border-radius: 25px; text-decoration: none; font-weight: bold; transition: all 0.3s; }
        .cart-btn:hover { background: #ccc; transform: scale(1.05); }

        /* Hero Banner - Scrolling Animation */
        .hero { height: 100vh; background: linear-gradient(45deg, #111, #222); display: flex; align-items: center; justify-content: center; text-align: center; position: relative; overflow: hidden; }
        .hero-content h1 { font-size: 4.5em; font-weight: bold; margin-bottom: 20px; animation: slideInUp 1s ease; }
        .hero-content .sale-badge { background: #ff4444; color: #fff; padding: 15px 40px; font-size: 1.5em; font-weight: bold; border-radius: 50px; display: inline-block; margin: 20px 0; animation: pulse 2s infinite; }
        .hero-content .extra-off { background: #fff; color: #000; padding: 12px 30px; font-size: 1.3em; font-weight: bold; border-radius: 30px; margin: 10px 0; animation: bounce 2s infinite; }
        .cta-btn { background: #fff; color: #000; padding: 20px 50px; font-size: 1.4em; font-weight: bold; border-radius: 50px; text-decoration: none; display: inline-block; margin-top: 30px; transition: all 0.3s; animation: slideInUp 1s ease 0.5s both; }
        .cta-btn:hover { transform: scale(1.1); box-shadow: 0 10px 30px rgba(255,255,255,0.3); }

        /* Floating Badges */
        .floating-badge { position: absolute; animation: float 6s ease-in-out infinite; }
        .free-shipping { top: 20%; right: 10%; background: #00ff88; color: #000; padding: 15px 25px; border-radius: 30px; font-weight: bold; }
        .cod-available { bottom: 20%; left: 10%; background: #ffaa00; color: #000; padding: 15px 25px; border-radius: 30px; font-weight: bold; animation-delay: 2s; }

        /* Products Section */
        .products { padding: 100px 0; background: #111; }
        .section-title { text-align: center; font-size: 3em; margin-bottom: 60px; letter-spacing: 3px; }
        .products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; }
        .product-card { background: #222; border-radius: 20px; overflow: hidden; transition: all 0.4s; position: relative; }
        .product-card:hover { transform: translateY(-20px); box-shadow: 0 30px 60px rgba(255,255,255,0.1); }
        .product-image { height: 300px; background: #333; position: relative; overflow: hidden; }
        .product-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
        .product-card:hover .product-image img { transform: scale(1.1); }
        .sale-tag { position: absolute; top: 20px; right: 20px; background: #ff4444; color: #fff; padding: 10px 20px; border-radius: 20px; font-weight: bold; }
        .product-info { padding: 30px; }
        .product-title { font-size: 1.4em; margin-bottom: 10px; }
        .product-price { font-size: 2em; font-weight: bold; color: #ff4444; margin-bottom: 15px; }
        .original-price { text-decoration: line-through; color: #888; font-size: 1.1em; margin-left: 10px; }
        .add-to-cart { background: #fff; color: #000; padding: 15px 30px; border: none; border-radius: 30px; font-weight: bold; width: 100%; cursor: pointer; transition: all 0.3s; }
        .add-to-cart:hover { background: #ccc; transform: scale(1.02); }

        /* Clearance Section */
        .clearance { padding: 100px 0; background: #000; position: relative; }
        .clearance::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 5px; background: linear-gradient(90deg, #ff4444, #ffaa00, #00ff88, #ff4444); animation: shimmer 3s infinite; }

        /* Footer */
        .footer { background: #111; padding: 60px 0 30px; text-align: center; }
        .footer-content { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px; margin-bottom: 40px; }
        .footer h3 { margin-bottom: 20px; color: #fff; }
        .footer a { color: #ccc; text-decoration: none; display: block; margin-bottom: 10px; transition: color 0.3s; }
        .footer a:hover { color: #fff; }

        /* Animations */
        @keyframes slideInUp { from { transform: translateY(50px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
        @keyframes bounce { 0%, 20%, 50%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-10px); } 60% { transform: translateY(-5px); } }
        @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-20px); } }
        @keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

        /* Responsive */
        @media (max-width: 768px) {
            .nav-menu { display: none; }
            .hero-content h1 { font-size: 2.5em; }
            .products-grid { grid-template-columns: 1fr; }
        }

        /* Scrolling Parallax */
        .parallax { background-attachment: fixed; background-position: center; background-repeat: no-repeat; background-size: cover; }
    </style>
</head>
